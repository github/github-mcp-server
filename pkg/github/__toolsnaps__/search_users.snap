{
  "annotations": {
    "readOnlyHint": true,
    "title": "Search users"
  },
  "description": "Find GitHub users by username, real name, or other profile information. Useful for locating developers, contributors, or team members.",
  "inputSchema": {
    "properties": {
      "fields": {
        "description": "Subset of fields to return for each user. If omitted, all fields are returned. Use this to reduce response size when you only need specific fields, e.g. just 'login'.",
        "items": {
          "enum": [
            "login",
            "id",
            "profile_url",
            "avatar_url",
            "details"
          ],
          "type": "string"
        },
        "type": "array"
      },
      "order": {
        "description": "Sort order",
        "enum": [
          "asc",
          "desc"
        ],
        "type": "string"
      },
      "page": {
        "description": "Page number for pagination (min 1)",
        "minimum": 1,
        "type": "number"
      },
      "perPage": {
        "description": "Results per page for pagination (min 1, max 100)",
        "maximum": 100,
        "minimum": 1,
        "type": "number"
      },
      "query": {
        "description": "User search query. Examples: 'john smith', 'location:seattle', 'followers:\u003e100'. Search is automatically scoped to type:user.",
        "type": "string"
      },
      "sort": {
        "description": "Sort users by number of followers or repositories, or when the person joined GitHub.",
        "enum": [
          "followers",
          "repositories",
          "joined"
        ],
        "type": "string"
      }
    },
    "required": [
      "query"
    ],
    "type": "object"
  },
  "name": "search_users"
}