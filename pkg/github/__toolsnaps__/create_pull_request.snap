{
  "_meta": {
    "ui": {
      "resourceUri": "ui://github-mcp-server/pr-write",
      "visibility": [
        "model",
        "app"
      ]
    }
  },
  "annotations": {
    "title": "Open new pull request"
  },
  "description": "Create a new pull request in a GitHub repository.",
  "inputSchema": {
    "properties": {
      "base": {
        "description": "Base branch name to merge into, e.g. main",
        "type": "string"
      },
      "body": {
        "description": "PR description; Markdown supported",
        "type": "string"
      },
      "draft": {
        "description": "Create as draft PR",
        "type": "boolean"
      },
      "head": {
        "description": "Branch containing changes, or owner:branch for a fork",
        "type": "string"
      },
      "maintainer_can_modify": {
        "description": "Allow maintainer edits",
        "type": "boolean"
      },
      "owner": {
        "description": "Repository owner",
        "type": "string"
      },
      "repo": {
        "description": "Repository name",
        "type": "string"
      },
      "title": {
        "description": "PR title",
        "type": "string"
      }
    },
    "required": [
      "owner",
      "repo",
      "title",
      "head",
      "base"
    ],
    "type": "object"
  },
  "name": "create_pull_request"
}